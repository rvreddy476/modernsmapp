REDIS_TLS_CA_CERT_FILE=/run/transport-certs/ca.crt
REDIS_TLS_AUTH_CLIENTS=no
KAFKA_TLS_ENABLED=true
KAFKA_TLS_SERVER_NAME=redpanda
KAFKA_CA_CERT_FILE=/run/transport-certs/ca.crt
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=appuser
KAFKA_SASL_PASSWORD=appuser_smoke_password
