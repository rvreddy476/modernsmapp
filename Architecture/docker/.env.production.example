# Production/staging environment template.
# Fill these values from a real secret manager or CI/CD secret store.

POSTGRES_USER=postgres
JWT_SECRET=
INTERNAL_SERVICE_KEY=
CHAT_PROXY_SIGNING_SECRET=

POSTGRES_PASSWORD=
IDENTITY_POSTGRES_USER=postgres
IDENTITY_POSTGRES_PASSWORD=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=true
REDIS_TLS_INSECURE_SKIP_VERIFY=
REDIS_TLS_SERVER_NAME=redis
REDIS_CA_CERT_FILE=/run/transport-certs/ca.crt
REDIS_CLIENT_CERT_FILE=
REDIS_CLIENT_KEY_FILE=
REDIS_TLS_CERT_FILE=/run/transport-certs/redis.crt
REDIS_TLS_KEY_FILE=/run/transport-certs/redis.key
REDIS_TLS_CA_CERT_FILE=/run/transport-certs/ca.crt
REDIS_TLS_AUTH_CLIENTS=no

MINIO_ROOT_USER=
# Keep these aligned with the root credentials unless you provision a separate MinIO app user.
MINIO_ROOT_PASSWORD=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
OPENSEARCH_INITIAL_ADMIN_PASSWORD=
GF_SECURITY_ADMIN_PASSWORD=
KAFKA_TLS_ENABLED=true
KAFKA_TLS_INSECURE_SKIP_VERIFY=
KAFKA_TLS_SERVER_NAME=redpanda
KAFKA_CA_CERT_FILE=/run/transport-certs/ca.crt
KAFKA_CLIENT_CERT_FILE=
KAFKA_CLIENT_KEY_FILE=
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_DIAL_TIMEOUT=
REDPANDA_SUPERUSER_USERNAME=
REDPANDA_SUPERUSER_PASSWORD=
REDPANDA_TLS_CERT_FILE=/run/transport-certs/redpanda.crt
REDPANDA_TLS_KEY_FILE=/run/transport-certs/redpanda.key
REDPANDA_TLS_CA_CERT_FILE=/run/transport-certs/ca.crt
# Host path containing `ca.crt`, `redis.crt`, `redis.key`, `redpanda.crt`, and `redpanda.key`.
TRANSPORT_CERTS_DIR=

CORS_ORIGINS=
ALLOWED_ORIGINS=
DOMAIN=
WS_ALLOW_QUERY_TOKEN=false
LIVEKIT_HOST=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
ICE_SERVERS_JSON=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_PATH=
APNS_BUNDLE_ID=

# Wallet (BC-of-PPI partner bank). See mini-apps/PHASE_2_DECISIONS.md §D1.
BANK_PARTNER=
PARTNER_BANK_VPA=

# Bill-pay (Setu BBPS aggregator). See mini-apps/PHASE_2_DECISIONS.md §D2.
SETU_MODE=
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_BASE_URL=
SETU_WEBHOOK_SECRET=

# Pulse (dating) + Mopedu (rider) Aadhaar verification via DigiLocker.
DIGILOCKER_MODE=
DIGILOCKER_BASE_URL=
DIGILOCKER_API_KEY=
DIGILOCKER_REDIRECT_URI=

# Internal-service auth (X-Internal-Service-Key header). Required by api-gateway,
# notification-service, dating-service, wallet-service, bill-pay-service, rider-service.
INTERNAL_SERVICE_KEY=

# Optional: per-domain Kafka topic overrides for notification-service consumers.
# Defaults: qa-events, dating-events, wallet-events, billpay-events, rider-events.
KAFKA_QA_TOPIC=
KAFKA_DATING_TOPIC=
KAFKA_WALLET_TOPIC=
KAFKA_BILLPAY_TOPIC=
KAFKA_RIDER_TOPIC=

# ─── Commerce production-launch envvars (TODO blocker #4) ─────────────────
#
# Without these set, the service falls back to stub implementations:
#   * RAZORPAY_* missing → stub gateway accepts everything (refuses to run
#     when DEPLOY_ENV=production unless PAYMENTS_ALLOW_STUB=true is also
#     set). Real money won't move.
#   * SHIPROCKET_* missing → stub courier auto-confirms "shipped" without
#     booking real consignments. Customer never receives a real label.
#   * MINIO_PUBLIC_ENDPOINT missing → invoice + settlement presigned URLs
#     point at the in-cluster MinIO endpoint and won't resolve from a
#     browser outside the docker network.

# Razorpay (payments-service + commerce-service).
RAZORPAY_WEBHOOK_SECRET=

# Shiprocket courier integration (commerce-service).
COURIER_PROVIDER=shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION_ID=

# MinIO browser-reachable endpoint. Used to rewrite presigned URLs so they
# resolve from the public internet (e.g. https://cdn.example.com).
MINIO_PUBLIC_ENDPOINT=

# Web-app public Razorpay key — surfaced to the Next.js bundle.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ─── Auth security (identity audit A7 + A10/A13/A15) ──────────────────────
#
# TOTP_ENCRYPTION_KEY: 64-char hex key (AES-256). Without this set, 2FA
# secrets are stored in plaintext — never run prod without it.
# OTEL_TRACES_SAMPLER_ARG: 0.0-1.0 sampling ratio. Default 1.0 in dev;
# set to 0.1 in production to bound collector cost.
TOTP_ENCRYPTION_KEY=
OTEL_TRACES_SAMPLER_ARG=0.1
