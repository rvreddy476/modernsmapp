# Local development defaults only.
# Copy to `.env` if you want Docker Compose to auto-load these values.

POSTGRES_USER=postgres
JWT_SECRET=local_dev_jwt_change_me
INTERNAL_SERVICE_KEY=local_dev_internal_service_key_change_me
CHAT_PROXY_SIGNING_SECRET=local_dev_chat_proxy_signing_secret_change_me

POSTGRES_PASSWORD=postgres
IDENTITY_POSTGRES_USER=postgres
IDENTITY_POSTGRES_PASSWORD=postgres
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_TLS_INSECURE_SKIP_VERIFY=false
REDIS_TLS_SERVER_NAME=
REDIS_CA_CERT_FILE=
REDIS_CLIENT_CERT_FILE=
REDIS_CLIENT_KEY_FILE=

MINIO_ROOT_USER=minio
# Keep these aligned with the root credentials unless you provision a separate MinIO app user.
MINIO_ROOT_PASSWORD=local_dev_minio_password_change_me
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=local_dev_minio_password_change_me
OPENSEARCH_INITIAL_ADMIN_PASSWORD=local_dev_opensearch_admin_password_change_me
GF_SECURITY_ADMIN_PASSWORD=local_dev_grafana_admin_password_change_me
KAFKA_TLS_ENABLED=false
KAFKA_TLS_INSECURE_SKIP_VERIFY=false
KAFKA_TLS_SERVER_NAME=
KAFKA_CA_CERT_FILE=
KAFKA_CLIENT_CERT_FILE=
KAFKA_CLIENT_KEY_FILE=
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_DIAL_TIMEOUT=10s

CORS_ORIGINS=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
DOMAIN=localhost
WS_ALLOW_QUERY_TOKEN=true
LIVEKIT_HOST=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
ICE_SERVERS_JSON=
