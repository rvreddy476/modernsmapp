{$DOMAIN:localhost} {
	# Frontend (Next.js)
	handle / {
		reverse_proxy nextjs:3000
	}
	handle /favicon.ico {
		reverse_proxy nextjs:3000
	}
	handle /_next/* {
		reverse_proxy nextjs:3000
	}

	# WebSocket gateway
	handle /v1/ws/* {
		reverse_proxy chat-ws-gateway:8093
	}

	# MinIO object storage
	handle /storage/* {
		uri strip_prefix /storage
		reverse_proxy minio:9000
	}

	# API gateway
	handle /v1/* {
		reverse_proxy api-gateway:8080
	}

	# Everything else -> frontend
	handle {
		reverse_proxy nextjs:3000
	}
}
