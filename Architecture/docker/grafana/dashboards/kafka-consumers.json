{
  "uid": "atpost-kafka-consumers",
  "title": "AtPost Kafka Consumers",
  "description": "Kafka consumer metrics: throughput, errors, DLQ, lag, and processing duration",
  "tags": ["atpost", "kafka", "consumers"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(atpost_kafka_messages_processed_total, job)",
        "query": "label_values(atpost_kafka_messages_processed_total, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "sort": 1
      },
      {
        "name": "consumer_group",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(atpost_kafka_messages_processed_total{job=~\"$service\"}, consumer_group)",
        "query": "label_values(atpost_kafka_messages_processed_total{job=~\"$service\"}, consumer_group)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "sort": 1
      },
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "selected": false,
          "text": "5m",
          "value": "5m"
        },
        "options": [
          { "selected": false, "text": "1m", "value": "1m" },
          { "selected": true, "text": "5m", "value": "5m" },
          { "selected": false, "text": "10m", "value": "10m" },
          { "selected": false, "text": "30m", "value": "30m" },
          { "selected": false, "text": "1h", "value": "1h" }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Messages Processed",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Message Processing Rate by Consumer Group",
      "description": "Rate of messages successfully processed per consumer group",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "msg/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job, consumer_group) (rate(atpost_kafka_messages_processed_total{job=~\"$service\", consumer_group=~\"$consumer_group\"}[$interval]))",
          "legendFormat": "{{ job }} / {{ consumer_group }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Processing Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Processing Error Rate by Consumer Group and Event Type",
      "description": "Rate of message processing errors per consumer group and event type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "errors/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job, consumer_group, event_type) (rate(atpost_kafka_processing_errors_total{job=~\"$service\", consumer_group=~\"$consumer_group\"}[$interval]))",
          "legendFormat": "{{ job }} / {{ consumer_group }} / {{ event_type }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "DLQ Messages",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Dead-Letter Queue Messages by Consumer Group",
      "description": "Cumulative count of messages sent to the dead-letter queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "messages",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job, consumer_group) (increase(atpost_kafka_dlq_messages_total{job=~\"$service\", consumer_group=~\"$consumer_group\"}[$interval]))",
          "legendFormat": "{{ job }} / {{ consumer_group }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Consumer Lag",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Consumer Lag by Topic and Partition",
      "description": "Number of messages the consumer is behind the latest offset, per topic/partition",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "lag",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (job, consumer_group, topic, partition) (atpost_kafka_consumer_lag{job=~\"$service\", consumer_group=~\"$consumer_group\"})",
          "legendFormat": "{{ job }} / {{ consumer_group }} / {{ topic }}-{{ partition }}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Processing Duration p99",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Message Processing Duration p99 by Consumer Group",
      "description": "99th percentile message processing duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "duration",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (job, consumer_group, le) (rate(atpost_kafka_processing_duration_seconds_bucket{job=~\"$service\", consumer_group=~\"$consumer_group\"}[$interval])))",
          "legendFormat": "{{ job }} / {{ consumer_group }}"
        }
      ]
    }
  ]
}
