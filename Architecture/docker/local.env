# ── New services wired in gap remediation ──────────────────────────────────

# Shared internal-service auth key (sent as X-Internal-Service-Key header)
export INTERNAL_SERVICE_KEY="dev_internal_key_change_me"

# OpenTelemetry OTLP endpoint (Jaeger / Grafana Tempo)
export OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Payment gateway — omit to use StubGateway in dev
export RAZORPAY_KEY_ID=""
export RAZORPAY_KEY_SECRET=""

# FCM push (Firebase HTTP v1) — omit to disable push in dev
export FCM_PROJECT_ID=""
export FCM_SERVICE_ACCOUNT_KEY=""

# APNs push (iOS) — omit to disable push in dev
export APNS_TEAM_ID=""
export APNS_KEY_ID=""
export APNS_PRIVATE_KEY_PATH=""
export APNS_BUNDLE_ID=""

# CSAM content scanner — disabled by default
export MEDIA_SCANNER_ENABLED="false"

# Auth service rate limiting
export RATE_LIMIT_ENABLED="true"
