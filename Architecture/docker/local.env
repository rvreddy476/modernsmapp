# ── Local development environment ──
# Source this before running Go services locally:
#   source local.env  (bash)   OR   set -a; . local.env; set +a

# ── Infrastructure (pointing to Docker containers on localhost) ──
export POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/app?sslmode=disable"
export IDENTITY_POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/identity_db?sslmode=disable"
export CHAT_POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/chat_db?sslmode=disable"
export COMMERCE_POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/commerce_db?sslmode=disable"
export FEED_POSTGRES_DSN="postgres://postgres:postgres@localhost:5432/feed_db?sslmode=disable"
export REDIS_ADDR="localhost:6379"
export SCYLLA_HOSTS="localhost"
export KAFKA_BROKERS="localhost:9092"
export MINIO_ENDPOINT="localhost:9000"
export MINIO_PUBLIC_ENDPOINT="http://localhost:9000"
export MINIO_ACCESS_KEY="minio"
export MINIO_SECRET_KEY="minio12345"
export MINIO_BUCKET="media"
export OPENSEARCH_URL="http://localhost:9200"
export JWT_SECRET="dev_secret_change_me"
export CORS_ORIGINS="http://localhost:3000"

